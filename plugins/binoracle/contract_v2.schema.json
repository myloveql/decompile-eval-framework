{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decompile-eval.local/schemas/binoracle.contract.v2.json",
  "title": "BinOracle Contract Graph V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sample_id",
    "contract_id",
    "abi",
    "arguments",
    "objects",
    "return",
    "relations",
    "globals",
    "dependencies",
    "unsupported_reasons",
    "confidence",
    "evidence_ids"
  ],
  "properties": {
    "schema_version": {"const": "binoracle.contract.v2"},
    "sample_id": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "minLength": 1},
    "abi": {"const": "x86_64_sysv"},
    "arguments": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot", "register", "kind_candidates", "confidence", "evidence_ids"],
        "properties": {
          "slot": {"type": "integer", "minimum": 0, "maximum": 2},
          "register": {"enum": ["RDI", "RSI", "RDX"]},
          "kind_candidates": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["integer", "pointer"]}
          },
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence_ids": {"type": "array", "items": {"type": "string"}},
          "object_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "objects": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "object_id", "argument_slot", "min_size", "alignment",
          "read_ranges", "write_ranges", "evidence_ids"
        ],
        "properties": {
          "object_id": {"type": "string", "minLength": 1},
          "argument_slot": {"enum": ["RDI", "RSI", "RDX"]},
          "min_size": {"type": "integer", "minimum": 1, "maximum": 16384},
          "alignment": {"type": "integer", "minimum": 1, "maximum": 4096},
          "read_ranges": {"$ref": "#/$defs/ranges"},
          "write_ranges": {"$ref": "#/$defs/ranges"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "return": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind_candidates", "confidence", "observable", "evidence_ids"],
      "properties": {
        "kind_candidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["void", "unknown", "integer", "object_pointer"]}
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "observable": {"type": "boolean"},
        "evidence_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "relations": {"type": "array", "items": {"type": "object"}},
    "globals": {"type": "array", "items": {"type": "object"}},
    "dependencies": {"type": "array", "items": {"type": "object"}},
    "unsupported_reasons": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "ranges": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          {"type": "integer", "minimum": 0},
          {"type": "integer", "minimum": 1}
        ],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      }
    }
  }
}
