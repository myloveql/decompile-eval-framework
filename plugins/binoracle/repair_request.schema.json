{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://binoracle.local/schemas/repair-request.v1.json",
  "title": "BinOracle Repair Request V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sample_id", "candidate_source", "compile_diagnostics", "frozen_harness_hash", "evidence_packages", "allowed_edit_scope", "iteration", "remaining_budget"],
  "properties": {
    "schema_version": {"const": "binoracle.repair-request.v1"},
    "sample_id": {"type": "string", "minLength": 1},
    "candidate_source": {"type": "string", "minLength": 1},
    "compile_diagnostics": {"type": "string"},
    "frozen_harness_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_packages": {"type": "array", "items": {"type": "object"}, "maxItems": 3},
    "allowed_edit_scope": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "iteration": {"type": "integer", "minimum": 0},
    "remaining_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iterations_remaining", "executions_remaining", "model_calls_remaining", "tokens_remaining"],
      "properties": {
        "iterations_remaining": {"type": "integer", "minimum": 0},
        "executions_remaining": {"type": "integer", "minimum": 0},
        "model_calls_remaining": {"type": "integer", "minimum": 0},
        "tokens_remaining": {"type": "integer", "minimum": 0}
      }
    }
  }
}
