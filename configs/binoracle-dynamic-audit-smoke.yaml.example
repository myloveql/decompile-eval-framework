# BinOracle V1 known-contract original-binary query. Linux/WSL x86-64 only.
# Copy configs/binoracle-known-contracts.json.example to a local .json file and fill real samples.
workspace_root: ../../..

datasets:
  - id: exebench-binoracle
    type: exebench_flat
    path: data/exebench/1641-Benchmark/exebench_1641_binoracle.with-ghidra.dataset.json
    include_path: third_party/exebench/exebench
    assembly_view: objdump_att_instruction_only
    pseudocode_view: ghidra
    expose_signature_metadata: false
    evaluation_protocol:
      type: exebench_json_io
    optimizations: [O0]
    limit: 10
    timeout: 30

decompilers:
  - id: binoracle-dynamic-audit-v1-sprint1
    type: python
    version: binoracle-backend-v1-sprint1
    plugin: plugins.binoracle_backend:BinOracleBackend
    required_inputs: [binary, assembly, pseudocode]
    batch_size: 1
    plugin_config:
      mode: dynamic_audit
      strict_privacy: true
      require_relocatable: true
      abi: sysv-x86_64
      contract_manifest: configs/binoracle-known-contracts.json
      runner_compiler: gcc
      runner_build_timeout: 120
      runner_execution_timeout_ms: 100
      max_executions: 1000

postprocessors:
  - markdown_fence
  - rename_target
  - ghidra_compat_types

metrics:
  - recompilable
  - behavioral_pass
  - plugins.binoracle_metrics:GeneratedTestCountMetric
  - plugins.binoracle_metrics:ExecutionCountMetric
  - plugins.binoracle_metrics:CounterexampleCountMetric
  - plugins.binoracle_metrics:RepairIterationCountMetric

executor:
  type: local
  require_linux: true
  memory_mb: 4096
  max_file_mb: 64

preflight:
  mode: strict

output:
  root: runs
  cache: .cache/decomp-eval
