workspace_root: ../../..

datasets:
  - id: decompile-eval
    type: decompile_eval
    path: data/decompile-eval
    splits: [humaneval, mbpp]
    assembly_view: asm
    pseudocode_view: ghidra_pseudo
    evaluation_protocol:
      type: decompile_eval_exitcode
    optimizations: [O0, O1, O2, O3]
    languages: [c]
    limit: 10
    timeout: 30

decompilers:
  - id: decompile-eval-fixed-ghidra-pseudo
    type: pseudocode
    version: "dataset-provided"

postprocessors: [markdown_fence, ghidra_compat_types]
metrics: [recompilable, behavioral_pass]

executor:
  type: local
  require_linux: true
  memory_mb: 4096
  max_file_mb: 64

preflight:
  mode: strict

output:
  root: runs
  cache: .cache/decomp-eval
